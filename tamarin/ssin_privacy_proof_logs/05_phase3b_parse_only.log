[Theory ssin_cahake_privacy_unlinkability_diff] Theory loaded
theory ssin_cahake_privacy_unlinkability_diff

begin

// Function signature and definition of the equational theory E

builtins: diffie-hellman
functions: adec/2, aenc/2, fst/1, pair/2, pk/1, snd/1, v1anon/4, v2anon/4
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2

rule (modulo E) Init_SB:
   [ Fr( ~ltkSB ) ]
  --[ InitSB( $SB ) ]->
   [ !LtkSB( $SB, ~ltkSB ), Out( pk(~ltkSB) ) ]

restriction UniqueInitSB [right]:
  "∀ sb #i #j. ((InitSB( sb ) @ #i) ∧ (InitSB( sb ) @ #j)) ⇒ (#i = #j)"
  // safety formula

restriction UniqueInitSB [left]:
  "∀ sb #i #j. ((InitSB( sb ) @ #i) ∧ (InitSB( sb ) @ #j)) ⇒ (#i = #j)"
  // safety formula

rule (modulo E) Init_Keys:
   [ Fr( ~xu1 ), Fr( ~xu2 ) ]
  --[ InitKeys( ) ]->
   [ !KeyS1( ~xu1 ), !KeyS2( diff(~xu1, ~xu2) ) ]

restriction UniqueInitKeys [right]:
  "∀ #i #j. ((InitKeys( ) @ #i) ∧ (InitKeys( ) @ #j)) ⇒ (#i = #j)"
  // safety formula

restriction UniqueInitKeys [left]:
  "∀ #i #j. ((InitKeys( ) @ #i) ∧ (InitKeys( ) @ #j)) ⇒ (#i = #j)"
  // safety formula

rule (modulo E) Session1:
   [
   Fr( ~mIsec ), Fr( ~mBsec ), Fr( ~TS ), !KeyS1( xu1 ),
   !LtkSB( $SB, ~ltkSB )
   ]
  --[ S1( $SB, 'g'^xu1^~mBsec ) ]->
   [
   Out( <aenc('g'^~mIsec, pk(~ltkSB)), 
         v1anon('g'^~mIsec, 'g'^~mBsec, 'g'^~mIsec^~mBsec, ~TS), ~TS, 
         'g'^xu1^~mBsec>
   )
   ]

rule (modulo E) Session2:
   [
   Fr( ~mIsec ), Fr( ~mBsec ), Fr( ~TS ), !KeyS2( xu2 ),
   !LtkSB( $SB, ~ltkSB )
   ]
  --[ S2( $SB, 'g'^xu2^~mBsec ) ]->
   [
   Out( <aenc('g'^~mIsec, pk(~ltkSB)), 
         v1anon('g'^~mIsec, 'g'^~mBsec, 'g'^~mIsec^~mBsec, ~TS), ~TS, 
         'g'^xu2^~mBsec>
   )
   ]

lemma unlink_executability [right]:
  exists-trace
  "∃ sb qb1 qb2 #t1 #t2. (S1( sb, qb1 ) @ #t1) ∧ (S2( sb, qb2 ) @ #t2)"
/*
guarded formula characterizing all satisfying traces:
"∃ sb qb1 qb2 #t1 #t2. (S1( sb, qb1 ) @ #t1) ∧ (S2( sb, qb2 ) @ #t2)"
*/
by sorry

lemma unlink_executability [left]:
  exists-trace
  "∃ sb qb1 qb2 #t1 #t2. (S1( sb, qb1 ) @ #t1) ∧ (S2( sb, qb2 ) @ #t2)"
/*
guarded formula characterizing all satisfying traces:
"∃ sb qb1 qb2 #t1 #t2. (S1( sb, qb1 ) @ #t1) ∧ (S2( sb, qb2 ) @ #t2)"
*/
by sorry

end
