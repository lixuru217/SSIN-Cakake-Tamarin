rule (modulo E) UEi_Public_Recv_Accept:
   [
   StUEi_Public( UEi, Di, SB, DB, ltkUEi, mIsec, hi, hB, Mi, MB, Qi, V1, TS5
   ),
   In( <SB, UEi, QB, V2, TS6> )
   ]
  --[
  Eq( adec(QB, ltkUEi), MB ),
  Eq( V2, v2tag(UEi, SB, Mi, MB, MB^mIsec, TS6) ),
  CheckTS6( UEi, SB, TS6 ), VerifiedV2AtUEi( UEi, SB, QB, V2, TS6 ),
  DeriveUEi( UEi, SB, MB^mIsec, skdf(MB^mIsec, UEi, Di, SB, DB, TS5, TS6)
  ),
  AcceptUEi( UEi, SB, skdf(MB^mIsec, UEi, Di, SB, DB, TS5, TS6), Mi, MB,
             Qi, QB, TS5, TS6
  )
  ]->
   [ ]

  /*
  rule (modulo AC) UEi_Public_Recv_Accept:
     [
     StUEi_Public( UEi, Di, SB, DB, ltkUEi, mIsec, hi, hB, Mi, MB, Qi, V1, TS5
     ),
     In( <SB, UEi, QB, V2, TS6> )
     ]
    --[
    Eq( z, MB ), Eq( V2, v2tag(UEi, SB, Mi, MB, z.1, TS6) ),
    CheckTS6( UEi, SB, TS6 ), VerifiedV2AtUEi( UEi, SB, QB, V2, TS6 ),
    DeriveUEi( UEi, SB, z.1, skdf(z.1, UEi, Di, SB, DB, TS5, TS6) ),
    AcceptUEi( UEi, SB, skdf(z.1, UEi, Di, SB, DB, TS5, TS6), Mi, MB, Qi, QB,
               TS5, TS6
    )
    ]->
     [ ]
    variants (modulo AC)
